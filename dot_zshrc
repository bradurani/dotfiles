# Chezmoi-managed .zshrc

export PATH="/opt/homebrew/bin:$HOME/.local/bin:$PATH"

[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

g() {
  if [ $# -eq 0 ]; then
    git status --short --branch
  elif [ "$1" = "root" ]; then
    cd "$(git rev-parse --show-toplevel 2>/dev/null)" || return
  else
    git "$@"
  fi
}
alias e='nvim'

# Completion paths
if command -v brew >/dev/null 2>&1; then
  local_brew_prefix=$(brew --prefix)
  local_completion_dirs=(
    /opt/homebrew/completions/zsh
    /opt/homebrew/share/zsh/site-functions
    /opt/homebrew/share/zsh-completions
    "$local_brew_prefix/share/zsh/site-functions"
  )
  for dir in $local_completion_dirs; do
    [ -d "$dir" ] && fpath=("$dir" $fpath)
  done
fi
autoload -Uz compinit
fpath=(${^fpath}(N-/))
local -a _insecure_compdirs
_insecure_compdirs=($(compaudit 2>/dev/null))
if (( ${#_insecure_compdirs} )); then
  fpath=(${fpath:|_insecure_compdirs})
fi
compinit

# OpenClaw completion
[ -f "$HOME/.openclaw/completions/openclaw.zsh" ] && source "$HOME/.openclaw/completions/openclaw.zsh"

chrome() {
  local debug_url="http://127.0.0.1:9222/json/version"
  if curl -fsS "$debug_url" >/dev/null 2>&1; then
    open -a "Google Chrome"
    return 0
  fi

  osascript -e 'tell application "Google Chrome" to quit' >/dev/null 2>&1 || true
  sleep 1
  open -na "Google Chrome" --args --restore-last-session --remote-debugging-port=9222 --user-data-dir="$HOME/Library/Application Support/Google/Chrome"
}

autoload -Uz colors && colors
setopt PROMPT_SUBST

git_branch() {
  local branch
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null) || return
  echo " (%F{magenta}${branch}%f)"
}

PROMPT='%F{cyan}%~%f$(git_branch) %# '
